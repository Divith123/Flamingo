{
  "name": "flamingo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.10",
      "hono": "^4.8.2",
      "@trpc/server": "^11.13.4",
      "better-auth": "^1.5.5",
      "stripe": "^17.5.0",
      "effect": "^3.19.14",
      "@effect/schema": "^0.75.5",
      "@effect/platform": "^0.95.0",
      "@effect/vitest": "^0.28.0",
      "vitest": "^3.1.1",
      "@vitest/ui": "^3.1.1",
      "@vitest/coverage-v8": "^3.1.1",
      "jsdom": "^26.0.0",
      "@playwright/test": "^1.58.2",
      "playwright": "^1.52.0",
      "@trpc/tanstack-react-query": "^11.13.4",
      "@trpc/client": "^11.13.4",
      "@tanstack/react-query": "^5.90.21",
      "zustand": "^5.0.5",
